<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TEMPLATE ONLY. Install with: bash scripts/install-companion-launchd.sh
  Live plist is written to ~/Library/LaunchAgents/ with TLS + PIN enabled.
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>app.grokbuild.companion</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/python3</string>
		<string>REPLACE_AT_INSTALL/acp_tcp_bridge.py</string>
		<string>--real</string>
		<string>--host</string>
		<string>127.0.0.1</string>
		<string>--port</string>
		<string>7391</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>2</integer>
</dict>
</plist>
